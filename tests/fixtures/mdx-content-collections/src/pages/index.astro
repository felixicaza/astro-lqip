---
import { getCollection } from 'astro:content'

const posts = await getCollection('blog')
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
  </head>
  <body>
    <div>
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </div>
  </body>
</html>
