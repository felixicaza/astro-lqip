---
import { Image, Picture, Background } from 'astro-lqip/components'

import volcanoImage from '../assets/pexels-fabianwiktor-3470872.jpg'
import volcanoSunsetImage from '../assets/pexels-fabianwiktor-3470482.jpg'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
  </head>
  <body>
    <div>
      <p>Background component ImageMetadata import</p>
      <Background src={volcanoSunsetImage}>
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component relative path import</p>
      <Background src="../assets/pexels-fabianwiktor-3470482.jpg">
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component absolute path import</p>
      <Background src="/src/assets/pexels-fabianwiktor-3470482.jpg">
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component alias path import</p>
      <Background src="@/assets/pexels-fabianwiktor-3470482.jpg">
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component with remote image</p>
      <Background src="https://images.pexels.com/photos/994605/pexels-photo-994605.jpeg">
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component with custom CSS variable</p>
      <Background src="/src/assets/pexels-fabianwiktor-3470482.jpg" cssVariable="--custom-background">
        <section class="custom-background">
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component in AVIF format</p>
      <Background src="/src/assets/pexels-fabianwiktor-3470482.jpg" format="avif">
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component with lqip color</p>
      <Background src="/src/assets/pexels-fabianwiktor-3470482.jpg" lqip="color">
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component in multiple formats</p>
      <Background src="/src/assets/pexels-fabianwiktor-3470482.jpg" format={['avif', 'webp', 'jpeg']}>
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component with custom width and height</p>
      <Background src="/src/assets/pexels-fabianwiktor-3470482.jpg" width={720} height={720}>
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Background component with several props</p>
      <Background src="/src/assets/pexels-fabianwiktor-3470482.jpg" format="avif" width={720} height={720} widths={[100, 1200, 1536]} quality={80} fit="cover">
        <section>
          <p>Optimized background</p>
        </section>
      </Background>
    </div>
    <div>
      <p>Image and Picture components ImageMetadata import</p>
      <Image width={450} height={450} src={volcanoImage} alt="A beautiful volcano" />
      <Picture width={450} height={450} src={volcanoImage} alt="A beautiful volcano in the sunset" />
    </div>
    <div>
      <p>Image and Picture components relative path import</p>
      <Image width={450} height={450} src="../assets/pexels-fabianwiktor-3470872.jpg" alt="A beautiful volcano" />
      <Picture width={450} height={450} src="../assets/pexels-fabianwiktor-3470872.jpg" alt="A beautiful volcano in the sunset" />
    </div>
    <div>
      <p>Image and Picture components absolute path import</p>
      <Image width={450} height={450} src="/src/assets/pexels-fabianwiktor-3470872.jpg" alt="A beautiful volcano" />
      <Picture width={450} height={450} src="/src/assets/pexels-fabianwiktor-3470872.jpg" alt="A beautiful volcano in the sunset" />
    </div>
    <div>
      <p>Image and Picture components import with alias</p>
      <Image width={450} height={450} src="@/assets/pexels-fabianwiktor-3470872.jpg" alt="A beautiful volcano" />
      <Picture width={450} height={450} src="@/assets/pexels-fabianwiktor-3470872.jpg" alt="A beautiful volcano in the sunset" />
    </div>
    <div>
      <p>Image and Picture components with remote images</p>
      <Image width={450} height={450} src="https://images.pexels.com/photos/994605/pexels-photo-994605.jpeg" alt="A beautiful volcano" />
      <Picture width={450} height={450} src="https://images.pexels.com/photos/994605/pexels-photo-994605.jpeg" alt="A beautiful volcano in the sunset" />
    </div>
  </body>
</html>

<style>
  section {
    background: var(--background);
  }
  .custom-background {
    background: var(--custom-background);
  }
  section,
  .custom-background {
    background-size: cover;
    background-position: center;
    width: 100%;
    height: 300px;
  }
</style>
