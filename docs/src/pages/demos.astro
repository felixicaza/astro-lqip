---
import { Image, Picture, Background } from 'astro-lqip/components'

import Layout from '@layouts/Layout.astro'

import Navbar from '@components/Navbar.astro'
import NextButton from '@components/NextButton.astro'
import Footer from '@components/Footer.astro'

import firstImage from '@images/pexels-fabianwiktor-3470482.jpg'
import secondImage from '@images/pexels-fabianwiktor-3470872.jpg'
import thirdImage from '@images/pexels-fabianwiktor-3470478.jpg'
---

<Layout title="Demos | Astro LQIP">
  <Navbar />
  <main class="container">
    <div>
      <label class="toggle-lqip">
        <input type="checkbox" />
        Show LQIP for Image and Picture components
      </label>
      <section>
        <div>
          <h3>LQIP Base64 (Default)</h3>
          <Picture
            src="../images/pexels-fabianwiktor-3470482.jpg"
            alt="A beautiful landscape with a lake and mountains 1"
            width={234}
            height={234}
            formats={['avif', 'webp']}
            fallbackFormat="webp"
          />
        </div>
        <div>
          <h3>LQIP Color</h3>
          <Image
            src="/src/images/pexels-fabianwiktor-3470872.jpg"
            alt="A beautiful landscape with a lake and mountains 2"
            width={234}
            height={234}
            lqip="color"
          />
        </div>
        <div>
          <h3>LQIP CSS</h3>
          <Picture
            src="@images/pexels-fabianwiktor-3470478.jpg"
            alt="A beautiful landscape with a lake and mountains 3"
            width={234}
            height={234}
            formats={['avif', 'webp']}
            fallbackFormat="webp"
            lqip="css"
          />
        </div>
        <div>
          <h3>LQIP SVG</h3>
          <Image
            src="https://images.pexels.com/photos/994605/pexels-photo-994605.jpeg"
            alt="A beautiful landscape with a lake and mountains 4"
            width={234}
            height={234}
            lqip="svg"
          />
        </div>
      </section>
      <section>
        <div>
          <h3>LQIP Base64 size 12</h3>
          <Image
            src={firstImage}
            alt="A beautiful landscape with a lake and mountains 5"
            width={234}
            height={234}
          />
        </div>
        <div>
          <h3>LQIP Color (not size)</h3>
          <Picture
            src={secondImage}
            alt="A beautiful landscape with a lake and mountains 6"
            width={234}
            height={234}
            formats={['avif', 'webp']}
            fallbackFormat="webp"
            lqip="color"
          />
        </div>
        <div>
          <h3>LQIP CSS size 12</h3>
          <Image
            src={thirdImage}
            alt="A beautiful landscape with a lake and mountains 7"
            width={234}
            height={234}
            lqip="css"
            lqipSize={8}
          />
        </div>
        <div>
          <h3>LQIP SVG size 12</h3>
          <Picture
            src="https://images.pexels.com/photos/994605/pexels-photo-994605.jpeg"
            alt="A beautiful landscape with a lake and mountains 8"
            width={234}
            height={234}
            formats={['avif', 'webp']}
            fallbackFormat="webp"
            lqip="svg"
            lqipSize={12}
          />
        </div>
      </section>
    </div>
    <div>
      <p>Background Component</p>
      <section>
        <div>
          <h3>LQIP Base64 (Default)</h3>
          <Background
            src="../images/pexels-fabianwiktor-3470482.jpg"
            width={234}
            height={234}
            format={['avif', 'webp']}
          >
            <section class="background-demo">
              <h3>A beautiful landscape with a lake and mountains 1</h3>
            </section>
          </Background>
        </div>
        <div>
          <h3>LQIP Color</h3>
          <Background
            src="/src/images/pexels-fabianwiktor-3470872.jpg"
            width={234}
            height={234}
            format={['avif', 'webp']}
            lqip="color"
          >
            <section class="background-demo">
              <h3>A beautiful landscape with a lake and mountains 2</h3>
            </section>
          </Background>
        </div>
        <div>
          <h3>LQIP Base64 (Default)</h3>
          <Background
            src="@images/pexels-fabianwiktor-3470478.jpg"
            width={234}
            height={234}
            format={['avif', 'webp']}
          >
            <section class="background-demo">
              <h3>A beautiful landscape with a lake and mountains 3</h3>
            </section>
          </Background>
        </div>
        <div>
          <h3>LQIP Color</h3>
          <Background
            src="https://images.pexels.com/photos/994605/pexels-photo-994605.jpeg"
            width={234}
            height={234}
            format={['avif', 'webp']}
            lqip="color"
          >
            <section class="background-demo">
              <h3>A beautiful landscape with a lake and mountains 4</h3>
            </section>
          </Background>
        </div>
      </section>
    </div>
    <NextButton href="/usage-tips" label="Tips" />
  </main>
  <Footer />
</Layout>

<script>
  const toggleLqipCheckbox = document.querySelector('.toggle-lqip input[type="checkbox"]')
  const images = document.querySelectorAll('[data-astro-lqip] img')

  toggleLqipCheckbox?.addEventListener('change', ({ target }) => {
    const isChecked = (target as HTMLInputElement).checked

    images.forEach(({ parentElement }) => parentElement?.style.setProperty('--opacity', isChecked ? '1' : '0'))
  })
</script>

<style>
  main {
    padding-block: 80px 40px;
    display: flex;
    flex-direction: column;
    gap: 48px;

    & > div {
      display: flex;
      flex-direction: column;
      gap: 32px;

      & label {
        cursor: pointer;
        width: fit-content;

        & input[type='checkbox'] {
          accent-color: #eebd53;
        }
      }

      & p {
        margin: 0;
      }

      & section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(234px, 1fr));
        gap: 8px;

        @media (width >= 1200px) {
          text-align: initial;
        }

        & h3 {
          font-size: 18px;
          font-weight: normal;
        }

        .background-demo {
          box-sizing: border-box;
          position: relative;
          background: var(--background) no-repeat;
          background-size: cover;
          height: 234px;
          border-radius: 4px;
          overflow: hidden;

          & > h3 {
            isolation: isolate;
            padding: 10px;
            text-align: center;
          }

          &::before {
            content: '';
            position: absolute;
            inset: 0;
            background: rgb(0 0 0 / 0.45);
            z-index: 0;
          }
        }
      }
    }
  }
</style>
